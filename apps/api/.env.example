DATABASE_URL="postgresql://itamls:itamls_dev_pw@localhost:5433/itamls?schema=public"
JWT_SECRET="change-me-in-production-please-32-chars-min"
JWT_EXPIRES_IN="1d"
PORT=4000
CORS_ORIGIN="http://localhost:5173"
WEB_BASE_URL="http://localhost:5173"

# MinIO / S3
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="itamls-invoices"

# Helpdesk integration. STUB returns demo tickets; FRESHSERVICE / JIRA_SM pull real ones.
HELPDESK_SYSTEM=STUB

# Web price lookup for SKUs.
#   SEARCH_LINKS — free, returns clickable shopping search URLs (default)
#   SERPAPI       — fully-automatic Google Shopping prices (requires paid SerpAPI key)
PRICE_LOOKUP_PROVIDER=SEARCH_LINKS
# SERPAPI_KEY=
# PRICE_LOOKUP_COUNTRY=za
# PRICE_LOOKUP_CURRENCY=ZAR

# SMTP for alert emails (leave empty to log-only / dry-run)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=ITAMLS <no-reply@fashionfusion.local>

# 2FA
TOTP_ISSUER=Fashion Fusion ITAMLS
