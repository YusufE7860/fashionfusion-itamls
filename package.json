{
  "name": "fashionfusion-itamls",
  "version": "0.1.0",
  "private": true,
  "description": "Fashion Fusion IT Asset Management & Logistics System (monorepo)",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "api:dev": "pnpm --filter @itamls/api dev",
    "api:migrate": "pnpm --filter @itamls/api prisma migrate dev",
    "api:seed": "pnpm --filter @itamls/api prisma db seed",
    "web:dev": "pnpm --filter @itamls/web dev",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "typescript": "5.4.5"
  }
}
